# R&D Task Management System - Environment Variables
# 复制此文件为 .env 并修改配置

# ==================== 服务器配置 ====================
# 后端服务器监听 IP（0.0.0.0 表示监听所有网卡）
SERVER_HOST=0.0.0.0
# 后端服务器监听端口
SERVER_PORT=5001

# ==================== MySQL 配置（环境变量优先） ====================
# 主数据库连接字符串（环境变量，覆盖 appsettings.json）
MYSQL_CONNECTION=Server=localhost;Port=3306;Database=TaskManageSystem;User=root;Password=your_password;CharSet=utf8mb4;SslMode=Preferred;
# 日志数据库连接字符串（环境变量，覆盖 appsettings.json）
MYSQL_LOG_CONNECTION=Server=localhost;Port=3306;Database=TaskManageSystem_Logs;User=root;Password=your_password;CharSet=utf8mb4;SslMode=Preferred;

# ==================== JWT 配置（环境变量优先） ====================
# JWT 密钥（环境变量，覆盖 appsettings.json）
JWT_SECRET_KEY=YourSuperSecretKey12345678901234567890
# JWT 签发者（可选，默认值见 appsettings.json）
JWT_ISSUER=TaskManageSystem
# JWT 受众（可选，默认值见 appsettings.json）
JWT_AUDIENCE=TaskManageSystemClient
